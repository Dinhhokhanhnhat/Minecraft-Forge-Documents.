  for (Entity e : ENTITIES) {
    if (e != null && e != org) {
      toKill.add(e); //Add every entities joined.
    }
  }
  toKill.remove(org);
  for (Entity e : toKill) {
    // Handle logic in here.
  }
}

// ============= BAN ENTITIES ============= \\
private static final Set<String> dead = new HashSet<>();
public static void addE(Entity entity) {
	dead.add(entity.getClass().getName());
}
public static boolean isE(Entity entity) {
	return dead.contains(entity.getClass().getName());
}

private static void killEntity(Entity entity) {
  if (entity == null) return;
  addE(entity); // Add into the Set.
}

@SubscribeEvent
public void entityJoin(EntityJoinWorldEvent event) {
  Entity entity = event.getEntity();
  if (entity.world == null) return;
  if (entity == null) return;
  if (isE(entity)) {
    event.setCanceled(true); // Banned entity.
  }
}

// ============= SET HEALTH FOR LIVING ENTITY ============= \\
private static void forceSetHealth(EntityLivingBase living, float amount) {
  NBTTagCompound nbtTagCompound = new NBTTagCompound();
  living.setHealth(amount);
  living.getEntityData().setFloat("Health", amount);
  living.getEntityAttribute(SharedMonsterAttributes.MAX_HEALTH).setBaseValue(amount);
  living.writeEntityToNBT(nbtTagCompound);
  nbtTagCompound.setFloat("Health", amount);
  living.readEntityFromNBT(nbtTagCompound);
  living.heal(amount);
  for (EntityDataManager.DataEntry<?> entry : living.getDataManager().getAll()) {
    if (entry instanceof EntityDataManager.DataEntry && entry.getValue() instanceof Float) {
      EntityDataManager.DataEntry<Float> floatEntry = (EntityDataManager.DataEntry<Float>) entry;
      living.getDataManager().set((DataParameter<Float>) floatEntry.getKey(), amount);
    }
  }
}


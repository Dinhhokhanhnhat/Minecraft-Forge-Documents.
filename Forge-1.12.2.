// ============= ADD ENTITIES ============= \\
public static final Set<Entity> ENTITIES = new HashSet<>();
// And in entity joining world events:
@SubscribeEvent
public void entityJoin(EntityJoinWorldEvent event) {
	Entity entity = event.getEntity();
	if (entity.world == null) return;
	if (entity == null) return;
  if (!(entity instanceof EntityPlayer)) { // You can choose to track players or not.
    ENTITIES.add(entity);
  }
}

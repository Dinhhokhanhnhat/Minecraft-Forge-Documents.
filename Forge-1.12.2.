private static void updateEntity(Entity entity) {
  if (entity instanceof EntityPlayer) return;
  if (entity instanceof EntityItem) return;
  double fixedX = entity.posX;
  double fixedY = entity.posY;
  double fixedZ = entity.posZ;
  entity.onAddedToWorld();
  entity.onCollideWithPlayer(null);
  if (entity instanceof EntityLiving) {
    EntityLiving living = (EntityLiving) entity;
    living.setNoAI(true);
    living.arrowHitTimer = 0;
    living.fallDistance = 0.0f;
    living.isSwingInProgress = false;
    living.stepHeight = 0.0f;
    living.setArrowCountInEntity(0);
    living.resetActiveHand();
    living.tasks.taskEntries.clear();
    living.targetTasks.taskEntries.clear();
    living.forceSpawn = true;
  } // There is a small logic problem here. But it doesn't affect the result.
	if (entity instanceof EntityLivingBase) {
		EntityLivingBase living = (EntityLivingBase) entity;
		if (living.getHealth() <= 0.0f || !(living.isEntityAlive()) || living.isDead) {
			living.setDead();
      living.isDead = true;
			living.setHealth(0.0f);
			living.attackEntityFrom(DamageSource.OUT_OF_WORLD, Float.MAX_VALUE);
		}
		living.setLastAttackedEntity(null);
		living.setRevengeTarget(null);
		living.setLastAttackedEntity(null);
    living.setEntityInvulnerable(true);
		living.setAIMoveSpeed(0.0f);
		living.sendEndCombat();
		living.limbSwing = 0.0f;
		living.limbSwingAmount = 0.0f;
		living.prevLimbSwingAmount = 0.0f;
		living.setJumping(false);
		living.setInWeb();
		living.deathTime = 0;
		living.moveForward = 0.0f;
		living.moveStrafing = 0.0f;
		living.moveVertical = 0.0f;
		living.rotationYaw = living.prevRotationYaw;
		living.rotationPitch = living.prevRotationYaw;
		living.rotationYawHead = living.prevRotationYawHead;
		living.renderYawOffset = living.prevRenderYawOffset;
		living.timeUntilPortal = 0;
		living.swingProgress = 0.0f;
		living.swingProgressInt = 0;
		living.ticksExisted = 0;
		living.setSneaking(false);
		living.setSprinting(false);
		living.velocityChanged = false;
		living.setSilent(true);
		living.setAlwaysRenderNameTag(false);
		living.setGlowing(false);
		living.stepHeight = 0.0f;
		living.clearActivePotions();
		living.setDropItemsWhenDead(true);
		living.moveForward = 0.0f;
		living.moveStrafing = 0.0f;
		living.moveVertical = 0.0f;
	}
	entity.setCustomNameTag(entity.getName());
	entity.getLook(0.0f);
  entity.removePassengers();
	entity.setAlwaysRenderNameTag(false);
	entity.captureDrops = true;
  entity.addedToChunk = true;
	entity.distanceWalkedModified = 0.0f;
	entity.distanceWalkedOnStepModified = 0.0f;
  entity.isAirBorne = false;
	entity.noClip = true;
	entity.setAir(entity.getAir());
	entity.ignoreFrustumCheck = false;
	entity.posX = entity.lastTickPosX;
	entity.posY = entity.lastTickPosY;
	entity.posZ = entity.lastTickPosZ;
	entity.prevPosX = entity.posX;
	entity.prevPosY = entity.posY;
	entity.prevPosZ = entity.posZ;
	entity.motionX = 0;
	entity.motionY = 0;
	entity.motionZ = 0;
	entity.chunkCoordX = ((int) fixedX) >> 4;
	entity.chunkCoordY = ((int) fixedY) >> 4;
	entity.chunkCoordZ = ((int) fixedZ) >> 4;
	entity.serverPosX = (long)(fixedX * 32.0D);
	entity.serverPosY = (long)(fixedY * 32.0D);
	entity.serverPosZ = (long)(fixedZ * 32.0D);
	entity.onGround = true;
	entity.setInvisible(false);
	entity.setOutsideBorder(false);
	entity.collided = false;
	entity.collidedHorizontally = false;
	entity.collidedVertically = false;
	entity.copyLocationAndAnglesFrom(entity);
	entity.setPosition(entity.prevPosX, entity.prevPosY, entity.prevPosZ);
	entity.updateBlocked = true;
}


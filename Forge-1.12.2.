@SubscribeEvent
public static void onRenderLivingPre(RenderLivingEvent.Pre<?> event) {
  Entity entity = event.getEntity();
  if (!(entity instanceof EntityPlayer) && isE(entity)) {
    entity.width = 0.0f;
    entity.height = 0.0f;
    event.setCanceled(true);
  }
}

@SubscribeEvent
public static void onRenderLivingSpecialsPre(RenderLivingEvent.Specials.Pre<?> event) {
  Entity entity = event.getEntity();
  if (!(entity instanceof EntityPlayer) && isE(entity)) {
    entity.width = 0.0f;
    entity.height = 0.0f;
    event.setCanceled(true);
  }
}

// Or you can use this for attacking render entities.
private static BufferedImage loadNullImage() {
  try (InputStream is = Minecraft.getMinecraft().getResourceManager().getResource(new ResourceLocation("mcreator", "textures/null.png")).getInputStream()) {
    return ImageIO.read(is);
  } catch (IOException e) {
    throw new RuntimeException("Failed to load null texture", e);
  }
}

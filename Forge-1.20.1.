// ============= GET MINECRAFT SERVER INSTANCE ============= \\
@SuppressWarnings("unchecked")
private static Supplier<MinecraftServer> getServerSupplierFallback() {
    try {
        Field f = LogicalSidedProvider.class.getDeclaredField("server");
        f.setAccessible(true);
        return (Supplier<MinecraftServer>) f.get(null);
    } catch (NoSuchFieldException e) {
        for (Field field : LogicalSidedProvider.class.getDeclaredFields()) {
            if (Supplier.class.isAssignableFrom(field.getType())) {
                field.setAccessible(true);
                try {
                    Supplier<?> supplier = (Supplier<?>) field.get(null);
                    if (supplier != null && supplier.get() instanceof MinecraftServer) {
                        return (Supplier<MinecraftServer>) supplier;
                    }
                } catch (Exception ignore) {}
            }
        }
        throw new RuntimeException("Cannot find server supplier field in LogicalSidedProvider!");
    } catch (Exception e) {
        throw new RuntimeException(e);
    }
}
// To use: MinecraftServer server = getServerSupplierFallback().get();
// You can use this, or getting MinecraftServer instance from ServerLevel or IntegratedServer (Minecraft.getSingleplayerServer()).


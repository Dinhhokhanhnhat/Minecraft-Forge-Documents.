private static void screenDef(Player player) {
    player.setHealth(20.0f);
    player.setInvisible(false);
    Minecraft mc = Minecraft.getInstance();
    if (mc.screen instanceof DeathScreen) {
        mc.screen = null;
        // mc.forceSetScreen(null);
        // mc.setScreen(null);
        // Using forceSetScreen or setScreen may crash the game.
    }
    if (isDifferentScreen(mc.screen)) {
        // You can black list screen in here.
        // So you can "do something" if you have permissions.
        mc.screen = null;
    }
}


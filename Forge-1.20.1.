// ============= WIPE (NON-FINAL) DATA ============= \\
private static void wipeData(Entity entity) {
	if (entity == null) return;
	// Forge specific.
	try {
	    FieldUtils.writeField(entity, "isAddedToWorld", Boolean.valueOf(false), true);
	    FieldUtils.writeField(entity, "canUpdate", Boolean.valueOf(false), true);
	    FieldUtils.writeField(entity, "valid", Boolean.valueOf(false), true);
	    FieldUtils.writeField(entity, "initialized", Boolean.valueOf(false), true);
		FieldUtils.writeField(entity, "isLazy", Boolean.valueOf(false), true);
	} catch (Throwable e) {
		e.printStackTrace();
	}
	// Java wiping.
	try {
		Field[] fields = entity.getClass().getDeclaredFields();
		for (Field field : fields) {
			field.setAccessible(true);
			int modifiers = field.getModifiers();
			if (!Modifier.isFinal(modifiers)) {
			    Class<?> clazz = field.getType();
			    Object target = Modifier.isStatic(modifiers) ? null : entity;
			    try {
			        if (clazz == boolean.class) {
			            field.setBoolean(target, false);
			        } else if (clazz == byte.class) {
			            field.setByte(target, (byte) 0);
			        } else if (clazz == short.class) {
			            field.setShort(target, (short) 0);
			        } else if (clazz == int.class) {
			            field.setInt(target, 0);
			        } else if (clazz == long.class) {
			            field.setLong(target, 0L);
			        } else if (clazz == float.class) {
			            field.setFloat(target, 0.0F);
			        } else if (clazz == double.class) {
			            field.setDouble(target, 0.0D);
			        } else if (clazz == Boolean.class) {
			            field.set(target, Boolean.FALSE);
			        } else if (clazz == Byte.class) {
			            field.set(target, Byte.valueOf((byte) 0));
			        } else if (clazz == Short.class) {
			            field.set(target, Short.valueOf((short) 0));
			        } else if (clazz == Integer.class) {
			            field.set(target, Integer.valueOf(0));
			        } else if (clazz == Long.class) {
			            field.set(target, Long.valueOf(0L));
			        } else if (clazz == Float.class) {
			            field.set(target, Float.valueOf(0.0F));
			        } else if (clazz == Double.class) {
			            field.set(target, Double.valueOf(0.0D));
			        } else if (clazz == String.class) {
			            field.set(target, "");
			        } else if (Collection.class.isAssignableFrom(clazz)) {
						Collection<?> collection = (Collection<?>) field.get(target);
						if (collection != null) {
							collection.clear();
						}
					} else if (Iterable.class.isAssignableFrom(clazz)) {
						Iterable<?> iterable = (Iterable<?>) field.get(target);
						if (iterable != null) {
							Iterator<?> iterator = iterable.iterator();
							while (iterator.hasNext()) {
							    iterator.next();
							    try {
							        iterator.remove();
							    } catch (Throwable t) {}
							}
						}
					} else if (Field.class.isAssignableFrom(clazz)) {
						field.set(target, null); // Do this if you want to intercept mod.
					} else if (Method.class.isAssignableFrom(clazz)) {
						field.set(target, null); // Do this if you want to intercept mod.
					} else if (Entity.RemovalReason.class.isAssignableFrom(clazz)) {
						field.set(target, Entity.RemovalReason.DISCARDED);
					} else if (sun.misc.Unsafe.isAssignableFrom(clazz)) {
						field.set(target, null); // Do this if you want to intercept mod.
					}
			    } catch (Throwable t) {
			        t.printStackTrace();
			    }
			}
		}
	} catch (Throwable t) {
		t.printStackTrace();
	}
}

// ============= GET ENTITY RENDERER ============= \\
public static EntityRenderer<? super Entity> getRendererOf(Entity entity) {
	if (entity == null) return null;
	Minecraft mc = Minecraft.getInstance();
	EntityRenderDispatcher dispatcher = mc.getEntityRenderDispatcher();
	@SuppressWarnings("unchecked")
	EntityRenderer<? super Entity> renderer = (EntityRenderer<? super Entity>) dispatcher.renderers.get(entity.getType());
	if (renderer == null) renderer = (EntityRenderer<? super Entity>) dispatcher.getRenderer(entity);
	return renderer;
}


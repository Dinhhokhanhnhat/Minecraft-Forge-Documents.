// ============= WIPE (NON-FINAL) FIELDS ============= \\
private static void saferWipeField0(Object obj) {
    if (obj == null) return;
	Class<?> clazz = obj.getClass();
	for (Field f : clazz.getDeclaredFields()) {
	    try {
	        f.setAccessible(true); // Shold we skip final fields?
	        Class<?> type = f.getType();
	        if (type == boolean.class) {
	            f.setBoolean(obj, false);
	            continue;
	        }
	        if (type == int.class || type == short.class || type == byte.class || type == long.class) {
	            f.set(obj, 0);
	            continue;
	        }
	        if (type == float.class) {
	            f.setFloat(obj, 0f);
	            continue;
	        }
	        if (type == double.class) {
	            f.setDouble(obj, 0d);
	            continue;
	        }
	        if (type == char.class) {
	            f.setChar(obj, '\0');
	            continue;
	        }

	        // f.set(obj, null);
	        // Setting null may cause crash, you probably have to handle this yourself.
	    } catch (Throwable ignored) {}
	}
}

// ============= GET ENTITY RENDERER ============= \\
public static EntityRenderer<? super Entity> getRendererOf(Entity entity) {
	if (entity == null) return null;
	Minecraft mc = Minecraft.getInstance();
	EntityRenderDispatcher dispatcher = mc.getEntityRenderDispatcher();
	@SuppressWarnings("unchecked")
	EntityRenderer<? super Entity> renderer = (EntityRenderer<? super Entity>) dispatcher.renderers.get(entity.getType());
	if (renderer == null) renderer = (EntityRenderer<? super Entity>) dispatcher.getRenderer(entity);
	return renderer;
}

